import React, { useEffect } from 'react';
import { useScheduleStore } from '../../store/useScheduleStore';
import { useAuthStore } from '../../store/useAuthStore';
import { Card } from '../../components/ui/Card';
import { Calendar, Clock } from 'lucide-react';
import { motion } from 'framer-motion';

export const StaffSchedule: React.FC = () => {
  const { shifts, fetchShiftsByStaff, isLoading } = useScheduleStore();
  const { user } = useAuthStore();
  
  useEffect(() => {
    if (user?.staffId) {
      fetchShiftsByStaff(user.staffId);
    }
  }, [user]);

  const publishedShifts = shifts.filter(s => s.status === 'PUBLISHED');

  return (
    <div className="space-y-6">
      <div>
        <h1 className="text-2xl font-bold text-gray-900 dark:text-white">My Schedule</h1>
        <p className="text-gray-500 dark:text-gray-400 mt-1">View your upcoming shifts</p>
      </div>

      <div className="grid grid-cols-1 gap-4">
        {publishedShifts.length === 0 ? (
          <Card className="p-8 text-center">
            <Calendar className="mx-auto h-12 w-12 text-gray-400 mb-4" />
            <h3 className="text-lg font-medium text-gray-900 dark:text-white">No Upcoming Shifts</h3>
            <p className="text-gray-500 dark:text-gray-400 mt-2">You don't have any published shifts right now.</p>
          </Card>
        ) : (
          publishedShifts.map((shift, i) => (
            <motion.div
              key={shift.id}
              initial={{ opacity: 0, y: 10 }}
              animate={{ opacity: 1, y: 0 }}
              transition={{ delay: i * 0.05 }}
            >
              <Card className="p-6 flex flex-col sm:flex-row items-center justify-between">
                <div className="flex items-center space-x-4 mb-4 sm:mb-0">
                  <div className="h-12 w-12 rounded-full bg-blue-100 dark:bg-blue-900 flex items-center justify-center text-blue-600 dark:text-blue-300">
                    <Calendar className="h-6 w-6" />
                  </div>
                  <div>
                    <h4 className="font-medium text-gray-900 dark:text-white">
                      {new Date(shift.startTime).toLocaleDateString(undefined, { weekday: 'long', month: 'long', day: 'numeric' })}
                    </h4>
                    <div className="flex items-center text-sm text-gray-500 dark:text-gray-400 mt-1">
                      <Clock className="h-4 w-4 mr-1.5" />
                      {new Date(shift.startTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })} - 
                      {new Date(shift.endTime).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                    </div>
                  </div>
                </div>
                <div className="flex flex-col items-end">
                  <span className="px-3 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 mb-2">
                    Confirmed
                  </span>
                  <span className="text-xs text-gray-500 uppercase tracking-wider">{shift.type.replace('_', ' ')}</span>
                </div>
              </Card>
            </motion.div>
          ))
        )}
      </div>
    </div>
  );
};
